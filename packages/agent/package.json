{
  "name": "@livepeer/agent",
  "version": "0.1.0-alpha.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "livepeer": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/cli.js",
    "./tools/types": {
      "types": "./dist/tools/types.d.ts",
      "import": "./dist/tools/types.js"
    },
    "./tools/registry": {
      "types": "./dist/tools/registry.d.ts",
      "import": "./dist/tools/registry.js"
    },
    "./providers/mock": {
      "types": "./dist/providers/mock.d.ts",
      "import": "./dist/providers/mock.js"
    },
    "./memory/working": {
      "types": "./dist/memory/working.d.ts",
      "import": "./dist/memory/working.js"
    },
    "./memory/session": {
      "types": "./dist/memory/session.d.ts",
      "import": "./dist/memory/session.js"
    },
    "./agent/runner": {
      "types": "./dist/agent/runner.d.ts",
      "import": "./dist/agent/runner.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "bun build src/index.ts --target=node --outdir=dist --external react --external ink --external ink-text-input --external react-devtools-core --external ws && bun build src/cli/index.ts --target=node --outfile=dist/cli.js --external react --external ink --external ink-text-input --external react-devtools-core --external ws --define 'process.env.DEV=\"false\"' && mkdir -p dist/bench/fixtures && cp src/bench/baseline.json dist/bench/baseline.json && cp src/bench/fixtures/*.txt dist/bench/fixtures/ && tsc --emitDeclarationOnly --outDir dist",
    "build:binary": "bun build src/cli/index.ts --compile --outfile=dist/livepeer",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/ink-testing-library": "^1.0.4",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "bun-types": "^1.1.30",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.0"
  }
}
